{
  "name": "odooo",
  "version": "1.0.0",
  "description": "Odoo hackathon 2026",
  "main": "index.js",
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "prisma:generate": "cd backend && npm run prisma:generate",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:deploy": "cd backend && npm run db:deploy",
    "db:seed": "cd backend && npm run db:seed",
    "db:reset": "cd backend && npm run db:reset",
    "db:studio": "cd backend && npm run db:studio"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dhanesh-vaghasiya/TransitOps.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/dhanesh-vaghasiya/TransitOps/issues"
  },
  "homepage": "https://github.com/dhanesh-vaghasiya/TransitOps#readme",
  "devDependencies": {
    "concurrently": "^9.2.4"
  }
}
